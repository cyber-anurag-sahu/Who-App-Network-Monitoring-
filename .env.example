# WhoApp Environment Configuration
# Copy this file to .env and edit values for your environment

# ── Network capture ────────────────────────────────────────────────
# The network interface to sniff on (live mode only)
# Linux: eth0, ens33, wlan0  |  macOS: en0  |  WSL2: eth0
CAPTURE_INTERFACE=eth0

# ── InfluxDB ────────────────────────────────────────────────────────
INFLUX_TOKEN=whoapp-super-secret-token
INFLUX_ORG=whoapp
INFLUX_BUCKET=network_flows
INFLUX_USER=admin
INFLUX_PASSWORD=whoapp1234

# ── Grafana ─────────────────────────────────────────────────────────
GF_USER=admin
GF_PASSWORD=whoapp1234

# ── Simulator ───────────────────────────────────────────────────────
# Playback speed multiplier (1.0 = real-time, 10.0 = 10x faster)
SIM_SPEED=5.0

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
